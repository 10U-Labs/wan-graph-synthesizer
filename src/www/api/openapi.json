        "x-amazon-apigateway-integration": {
          "uri": "${CarriersHandlerArn}",
          "httpMethod": "POST",
          "type": "aws_proxy"
        }
      },
      "put": {
        "summary": "Replace a carrier's PoPs (cascades a rebuild).",
        "parameters": [
          { "name": "carrier", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "The carrier's vertices were replaced." } },
        "x-amazon-apigateway-integration": {

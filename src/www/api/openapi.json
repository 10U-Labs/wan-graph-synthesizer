{
  "openapi": "3.0.1",
  "info": {
    "title": "wan-graph-designer",
    "description": "Graphs as REST resources: carriers, CSPs, the carrier merge (substrate), and customers' WANs. Inputs are writable; computed graphs are read-only. One JSON format throughout.",
